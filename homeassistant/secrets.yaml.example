# Ejemplo de secrets.yaml para Home Assistant
# Copiar a secrets.yaml en el config de HA y rellenar los valores reales.

# URL de la API de calidad del aire (Open-Meteo — gratuita, sin clave).
# Sustituye LAT y LON por las coordenadas de tu ubicación.
# Puedes obtenerlas en: https://www.latlong.net/ o buscando tu ciudad en Google Maps.
# Ejemplo para Oviedo, España: latitude=43.3603&longitude=-5.8448
# air_quality_url: "https://air-quality-api.open-meteo.com/v1/air-quality?latitude=43.3603&longitude=5.8448&current=pm2_5,pm10"

air_quality_url: "https://air-quality-api.open-meteo.com/v1/air-quality?latitude=LAT&longitude=LON&current=pm2_5,pm10"
